{
  "$schema": "https://openapi.vercel.sh/vercel.json",
  "framework": "nextjs",
  "installCommand": "npm ci",
  "crons": [
    {
      "path": "/api/cron/send-reminders",
      "schedule": "0 * * * *"
    },
    {
      "path": "/api/cron/weekly-digest",
      "schedule": "0 13 * * 1"
    },
    {
      "path": "/api/cron/reap-pairings",
      "schedule": "10 4 * * *"
    },
    {
      "path": "/api/cron/prune-activity-events",
      "schedule": "20 4 * * *"
    }
  ],
  "redirects": [
    {
      "source": "/:path*",
      "has": [
        {
          "type": "host",
          "value": "fromvictoryapp.com"
        }
      ],
      "destination": "https://www.fromvictoryapp.com/:path*",
      "permanent": true
    }
  ]
}
