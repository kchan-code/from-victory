# Public site URL used in metadata and absolute links.
NEXT_PUBLIC_SITE_URL=http://localhost:3000

# Supabase — public values (safe to expose; protected by RLS).
# Local dev defaults shown; replace with real project values for remote envs.
NEXT_PUBLIC_SUPABASE_URL=http://127.0.0.1:54321
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# Supabase service role key — SERVER-SIDE ONLY. NEVER expose to the client.
# Used by server actions and the Stripe webhook handler to bypass RLS where
# needed (e.g., parent-initiated athlete account creation, webhook writes).
# Leave blank in .env.example; populate in .env.local (gitignored).
SUPABASE_SERVICE_ROLE_KEY=

# ---------------------------------------------------------------------------
# Device-pairing cookie HMAC secret — SERVER-SIDE ONLY. Never prefix with
# NEXT_PUBLIC_. Signs the welcome-back device cookie (fv_device_athlete_id /
# __Host-fv_device_athlete_id) so a forged or unsigned cookie cannot trigger
# the athlete first-name lookup on /signin (FV-13).
#
# Rotating this key invalidates all existing welcome-back cookies. Athletes
# will see the generic parent sign-in form once, then re-pair normally. Real
# Supabase-session auth is unaffected — only the convenience UX is reset.
#
# Generate with: openssl rand -base64 32
# Dev placeholder shown below is NOT secure; never use it in production.
# ---------------------------------------------------------------------------
DEVICE_COOKIE_HMAC_SECRET=dev-only-device-cookie-hmac-secret-not-for-prod

# ---------------------------------------------------------------------------
# Stripe — all values come from your Stripe project dashboard.
# KC: see "Open Items" in CLAUDE.md for the Stripe project setup step.
# ---------------------------------------------------------------------------

# Stripe secret key — SERVER-SIDE ONLY. Never prefix with NEXT_PUBLIC_.
# Found in Stripe Dashboard → Developers → API keys → Secret key.
# Use the test-mode key (sk_test_...) for local dev; live key (sk_live_...)
# only in the production environment.
STRIPE_SECRET_KEY=

# Stripe webhook signing secret — SERVER-SIDE ONLY.
# Found in Stripe Dashboard → Developers → Webhooks → <endpoint> → Signing secret.
# For local development, use the Stripe CLI: `stripe listen --forward-to localhost:3000/api/webhooks/stripe`
# which prints a whsec_... secret for use here.
STRIPE_WEBHOOK_SECRET=

# Stripe Price IDs for the two plans.
# Found in Stripe Dashboard → Products → <product> → Pricing → Price ID (price_...).
# These are safe to expose server-side; they are NOT the secret key.
STRIPE_PRICE_ID_MONTHLY=
STRIPE_PRICE_ID_ANNUAL=

# Stripe publishable key — safe to expose to the browser (NEXT_PUBLIC_ prefix).
# Found in Stripe Dashboard → Developers → API keys → Publishable key.
# Used by the future checkout UI (Stripe.js / Elements) — not yet wired.
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=

# ---------------------------------------------------------------------------
# Email (Resend) — for transactional email and waitlist notifications.
# ---------------------------------------------------------------------------

# Resend API key — SERVER-SIDE ONLY. Get from resend.com → API Keys.
RESEND_API_KEY=

# Comma-separated list of email addresses that have admin access.
# Used by apps/web/lib/auth/admin.ts to gate admin routes.
ADMIN_EMAILS=

# Waitlist notification recipients (Resend). Notified when a new waitlist
# signup arrives. SERVER-SIDE ONLY.
WAITLIST_NOTIFICATION_TO=
WAITLIST_NOTIFICATION_FROM=

# ---------------------------------------------------------------------------
# Error alerting (Resend) — FV-167
# KC receives an email when an infrastructure failure occurs (webhook DB
# write, Stripe API error, safety event log failure, auth rollback, etc.).
# Both vars must be set; alerts are silently skipped if either is missing.
# SERVER-SIDE ONLY. ALERT_EMAIL_FROM must be a Resend-verified sender domain.
# Set both in Vercel env vars (all environments) before FV-7 Stripe launch.
# ---------------------------------------------------------------------------
ALERT_EMAIL_TO=your-alert-address@example.com
ALERT_EMAIL_FROM=
