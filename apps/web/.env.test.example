# ============================================================================
# From Victory — E2E test environment
#
# Copy this file to .env.test and fill in real values.
# .env.test is gitignored; NEVER commit real keys.
#
# ALL values here MUST point at the LOCAL Supabase stack or a dedicated
# isolated test project. The prod project ref (kumrgeosgzdlxgljbyju) is
# hard-blocked in global-setup.ts — the test suite will refuse to run if
# E2E_SUPABASE_URL contains it.
# ============================================================================

# Base URL where the Next.js dev server is running during tests.
# Default is http://localhost:3000 — only change if you run on a different port.
E2E_BASE_URL=http://localhost:3000

# ---------------------------------------------------------------------------
# Supabase — LOCAL STACK (default: `supabase start`)
# Run `supabase status` to get these values after starting the local stack.
# ---------------------------------------------------------------------------
E2E_SUPABASE_URL=http://127.0.0.1:54321
E2E_SUPABASE_ANON_KEY=<local-anon-key-from-supabase-status>
E2E_SUPABASE_SERVICE_ROLE_KEY=<local-service-role-key-from-supabase-status>

# Device-pairing cookie HMAC secret — SERVER-SIDE ONLY (FV-13).
# The test/E2E environment can use any fixed value; the dev fallback in
# device.ts will also kick in if this is unset in non-production environments.
DEVICE_COOKIE_HMAC_SECRET=dev-only-device-cookie-hmac-secret-not-for-prod

# ---------------------------------------------------------------------------
# These mirror the Next.js public env vars so the dev server picks them up.
# The playwright.config.ts webServer block forwards these automatically, but
# keeping them here makes the .env.test self-documenting.
# ---------------------------------------------------------------------------
NEXT_PUBLIC_SUPABASE_URL=http://127.0.0.1:54321
NEXT_PUBLIC_SUPABASE_ANON_KEY=<same-as-E2E_SUPABASE_ANON_KEY>
SUPABASE_SERVICE_ROLE_KEY=<same-as-E2E_SUPABASE_SERVICE_ROLE_KEY>
NEXT_PUBLIC_SITE_URL=http://localhost:3000
